# ── Backend (prefix TG_) ────────────────────────────────────────────────
# SQLite for native runs; the Docker stack uses Postgres (see docker-compose.yml).
TG_DATABASE_URL=sqlite:///./temple_guard.db
# Postgres password for the Docker stack (docker compose / start.sh).
TG_DB_PASSWORD=temple
# execution_mode: simulation | docker | cloud_vm | k8s
TG_EXECUTION_MODE=simulation
TG_DOCKER_KALI_IMAGE=kalilinux/kali-rolling
TG_ENFORCE_SCOPE=true
TG_SCAN_TIMEOUT_SECONDS=900
TG_SCAN_CONCURRENCY=4
TG_CORS_ORIGINS=http://localhost:3000

# ── AWS cloud-VM provisioner (optional) ─────────────────────────────────
# Leave blank to keep it disabled. When set (and boto3 + AWS creds present),
# scans for engagements with provisioner=cloud_vm launch an ephemeral EC2
# instance, run the tool over SSM, and terminate it.
TG_AWS_REGION=
TG_AWS_KALI_AMI=
TG_AWS_SUBNET_ID=
TG_AWS_SECURITY_GROUP_ID=
TG_AWS_INSTANCE_TYPE=t3.medium
TG_AWS_KEY_NAME=
TG_AWS_IAM_INSTANCE_PROFILE=

# ── Frontend ────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_BASE=http://localhost:8000
